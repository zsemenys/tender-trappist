---
// Tady nahoře můžeme definovat "vstupy" pro kartu
const { nazev = "Produkt", popis = "Popis produktu..." } = Astro.props;
---

<div class="bg-white border-l-8 border-orange-500 p-6 shadow-lg rounded-r-xl hover:shadow-2xl transition-all group">
    <h3 class="text-2xl font-bold text-blue-900 group-hover:text-orange-600 transition-colors">
        {nazev}
    </h3>
    <p class="text-slate-600 mt-2">
        {popis}
    </p>
    <button class="mt-4 px-4 py-2 bg-blue-700 text-white rounded-lg hover:bg-blue-800">
        Zjistit více
    </button>
</div>