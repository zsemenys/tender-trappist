---
// Header.astro

const navLinks = [
  { name: 'Úvod', href: '/' },
  { 
    name: 'Produkty a služby', 
    href: '#', 
    submenu: [
      { name: 'Bateriová úložiště', href: '/produkty-a-sluzby/bateriova-uloziste' },
      { name: 'Monitoring FVE', href: '/produkty-a-sluzby/monitoring' },
      { name: 'Dispečink', href: '/produkty-a-sluzby/dispecink' },
      { name: 'Servis a revize', href: '/produkty-a-sluzby/servis' },
      { name: 'Opravy měničů', href: '/produkty-a-sluzby/opravy-menicu' },
    ]
  },
  { name: 'Katalog', href: '/eshop' },
  { name: 'O společnosti', href: '/o-spolecnosti' },
  { name: 'Kontakty', href: '/kontakty' },
  { name: 'Něco', href: '/neco' },
];
---

<header class="sticky top-0 z-50 w-full bg-white border-b border-slate-100 shadow-sm">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-20">
      
      <a href="/" class="shrink-0">
        <img src="https://www.solarmon.eu/images/layout/img_logo.png" alt="SOLARMONITORING" class="h-10 w-auto"/>
      </a>

      <nav class="hidden lg:flex items-center gap-6">
        {navLinks.map((link) => (
          <div class="relative group">
            <a href={link.href} class="flex items-center gap-1 text-sm font-bold text-slate-700 hover:text-green-600 py-8 transition-colors">
              {link.name}
              {link.submenu && <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>}
            </a>
            
            {link.submenu && (
              <div class="absolute left-0 top-[calc(100%-10px)] hidden group-hover:block w-56 pt-2">
                <div class="bg-white border border-slate-100 shadow-xl rounded-xl overflow-hidden p-2">
                  {link.submenu.map((sub) => (
                    <a href={sub.href} class="block px-4 py-2 text-sm text-slate-600 hover:bg-green-50 hover:text-green-700 rounded-lg transition-colors">
                      {sub.name}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <button id="menu-toggle" class="lg:hidden p-2 text-slate-600" aria-label="Menu">
        <svg id="icon-open" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
        <svg id="icon-close" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
  </div>

 <div 
  id="mobile-menu" 
  class="hidden lg:hidden border-t border-slate-100 bg-white w-full max-h-[calc(100vh-80px)] overflow-y-auto"
>
  <nav class="flex flex-col">
    {navLinks.map((link) => (
      <div class="border-b border-slate-50 last:border-0">
        {link.submenu ? (
          <div class="flex flex-col">
            <button class="submenu-trigger flex items-center justify-between w-full px-6 py-5 text-base font-bold text-slate-800 hover:bg-slate-50 transition-colors">
              {link.name}
              <svg class="w-5 h-5 text-slate-400 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            
            <div class="hidden flex-col bg-slate-50 px-6 py-2">
              {link.submenu.map((sub) => (
                <a 
                  href={sub.href} 
                  class="block py-3 text-sm font-semibold text-slate-600 hover:text-green-600 transition-colors border-l-2 border-transparent hover:border-green-500 pl-4"
                >
                  {sub.name}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a 
            href={link.href} 
            class="block px-6 py-5 text-base font-bold text-slate-800 hover:bg-slate-50 transition-colors"
          >
            {link.name}
          </a>
        )}
      </div>
    ))}
   
      <a href="/kontakty" class="mt-6 block w-full py-4 bg-green-600 text-white text-center font-bold rounded-xl shadow-md">
        Poptat servis
      </a>
    </nav>
  </div>
</header>

<script>
  // Hlavní toggle pro mobilní menu
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', isHidden);
    document.body.style.overflow = isHidden ? '' : 'hidden';
  });

  // Logika pro rozbalování submenu v mobilu
  const submenuTriggers = document.querySelectorAll('.submenu-trigger');
  
  submenuTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const submenu = trigger.nextElementSibling;
      const icon = trigger.querySelector('svg');
      
      const isHidden = submenu?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180', !isHidden);
    });
  });
</script>